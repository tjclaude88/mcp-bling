{
  "name": "bling-bag",
  "version": "0.1.1",
  "mcpName": "io.github.tjclaude88/bling-bag",
  "description": "MCP server that delivers bot identity and visual styling",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bling-bag": "dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "bling.json.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "bot",
    "identity",
    "styling",
    "claude"
