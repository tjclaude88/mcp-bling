  "author": "tjclaude <tjclaude@proton.me>",
  "license": "MIT",
  "homepage": "https://github.com/tjclaude88/mcp-bling#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjclaude88/mcp-bling.git"
  },
  "bugs": {
    "url": "https://github.com/tjclaude88/mcp-bling/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
